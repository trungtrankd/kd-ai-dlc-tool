{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "lib": ["ES2020"],
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", ".vscode-test", "src/webview/**/*", "vite.config.ts", "tsconfig.webview.json", "tailwind.config.js", "postcss.config.js"]
}
